# TacitIQ Frontend Environment Variables Template

# Deployed Backend API Base URL (e.g., https://tacitiq-backend.onrender.com)
# Leave empty for local development behind Vite proxy (defaults to relative /api)
VITE_API_BASE_URL=https://your-tacitiq-backend.onrender.com

# Google OAuth Client ID (must match Authorized JavaScript Origins in Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
