# TacitIQ Consolidated Production Environment Variables Reference
# Copy values to frontend and backend deployment services (Vercel / Render / Docker).

# ==========================================
# Frontend Configuration (Vercel)
# ==========================================
VITE_API_BASE_URL=https://your-tacitiq-backend.onrender.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ==========================================
# Backend Configuration (Render)
# ==========================================
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://your-db-host:5432/tacitiq
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# Authentication & Security
JWT_SECRET=your_production_jwt_secret_min_64_chars
CORS_ALLOWED_ORIGINS=https://your-tacitiq-frontend.vercel.app
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Graph Database (Neo4j / AuraDB)
NEO4J_URI=neo4j+s://your-auradb-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Caching Layer (Redis)
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
