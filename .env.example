# TacitIQ Environment Variables Template
# Copy this file to '.env' and update variables as needed.

# Google Gemini API key (for AI Operations Assistant context generation)
# If left blank, TacitIQ will run in robust Offline Mock Mode with pre-defined rules.
GEMINI_API_KEY=

# Google OAuth Configuration (Client ID)
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
