# TacitIQ Backend Production Environment Variables Template

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Server Port
PORT=8080

# PostgreSQL Database Configuration
DATABASE_URL=jdbc:postgresql://your-db-host:5432/tacitiq
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# JWT Security Key (Generate a 64+ char random secret)
JWT_SECRET=your_production_jwt_secret_min_64_chars_hex_or_string

# CORS Allowed Origins (Comma-separated list of deployed frontend URLs)
CORS_ALLOWED_ORIGINS=https://your-tacitiq-frontend.vercel.app

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Neo4j Graph Database (AuraDB or self-hosted)
NEO4J_URI=neo4j+s://your-neo4j-auradb-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis Caching Layer
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
